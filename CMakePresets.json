{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "ci-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "ENABLE_VULKAN": "OFF"
      }
    },
    {
      "name": "dev-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "ENABLE_VULKAN": "ON"
      }
    },
    {
      "name": "ci-windows",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build/ci-windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "ci-linux",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build/ci-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dev-windows",
      "inherits": "dev-base",
      "binaryDir": "${sourceDir}/build/dev-windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dev-linux",
      "inherits": "dev-base",
      "binaryDir": "${sourceDir}/build/dev-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ci-windows",
      "configurePreset": "ci-windows",
      "configuration": "Release"
    },
    {
      "name": "ci-linux",
      "configurePreset": "ci-linux",
      "configuration": "Release"
    },
    {
      "name": "dev-windows",
      "configurePreset": "dev-windows",
      "configuration": "Debug"
    },
    {
      "name": "dev-linux",
      "configurePreset": "dev-linux",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "ci-windows",
      "configurePreset": "ci-windows",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-linux",
      "configurePreset": "ci-linux",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-windows",
      "configurePreset": "dev-windows",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-linux",
      "configurePreset": "dev-linux",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
